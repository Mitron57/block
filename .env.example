# Backend (twelve-factor: config via environment)
DATABASE_URL=postgres://board:board@localhost:5432/board
JWT_SECRET=change-me-to-long-random-secret-in-production
HOST=0.0.0.0
PORT=3000
RUST_LOG=board_server=debug,tower_http=debug

# Frontend (Vite) — copy to frontend/.env.local for local dev
VITE_API_URL=http://localhost:3000
