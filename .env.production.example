# Переменные задаются в Railway (Variables) для каждого сервиса.
# Публичный URL edge-сервиса proxy (для CORS):
FRONTEND_ORIGIN=https://<your-proxy>.up.railway.app

# board-api (ссылка на плагин PostgreSQL):
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# JWT_SECRET=<случайная строка ≥ 32 символов>

# proxy (private networking, имена сервисов как в Railway):
# BOARD_API_HOST=${{board-api.RAILWAY_PRIVATE_DOMAIN}}
# FRONTEND_HOST=${{frontend.RAILWAY_PRIVATE_DOMAIN}}
