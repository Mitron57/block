# Скопировать на ВМ: cp .env.production.example .env.production

CR_IMAGE_API=cr.yandex/<registry_id>/board-api:latest
CR_IMAGE_FRONTEND=cr.yandex/<registry_id>/board-frontend:latest
CR_IMAGE_PROXY=cr.yandex/<registry_id>/board-proxy:latest

DATABASE_URL=postgres://board:<password>@c-<cluster>.rw.mdb.yandexcloud.net:6432/board?sslmode=require
JWT_SECRET=
FRONTEND_ORIGIN=http://<public-ip-или-домен>
